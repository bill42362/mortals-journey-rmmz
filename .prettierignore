#     結果反而視覺錯位且造成大量 diff，故 docs 維持手寫。
*.md

# --- 素材 / 二進位 / 輸出 ---
game/img/
game/audio/
game/fonts/
game/effects/
game/movies/
game/icon/
node_modules/
dist/
