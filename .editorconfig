root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown：行尾空白有語意（強制換行），不裁切
[*.md]
trim_trailing_whitespace = false

# RMMZ 引擎產生的資料/程式：不在此規範（交給引擎），避免誤導工具
[game/data/**]
insert_final_newline = unset
trim_trailing_whitespace = unset
