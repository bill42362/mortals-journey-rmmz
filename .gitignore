# =========================================================
#  開發工具 / 套件
# =========================================================
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================================
#  OS / 編輯器雜物
# =========================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
*.swp
*~

# 只追蹤共用的 VSCode 設定，其餘個人化檔案不入庫
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# =========================================================
#  RMMZ 執行期 / 編輯器產物
# =========================================================
# 試玩存檔（playtest saves）— 因人而異、不應入庫
game/save/
*.rmmzsave
*.rpgsave

# RMMZ 編輯器暫存 / 備份
game/data/*.json.bak
*.tmp

# =========================================================
#  部署 / 建置輸出
# =========================================================
# RMMZ 編輯器的 web/desktop deploy 輸出（我們直接託管 game/ 本身，不入庫匯出複本）
/dist/
/deploy/
/output/
